rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Waitlist signups — anyone may add themselves (newcomers are gated here
    // instead of creating an account). Entries are private: no client reads,
    // updates, or deletes. Review happens via the Admin SDK / console.
    match /waitlist/{entry} {
      allow create: if request.resource.data.keys().hasOnly(
                         ['email', 'name', 'source', 'createdAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 3
                    && request.resource.data.email.size() < 320;
      allow read, update, delete: if false;
    }

    // User profile document — owned by the authenticated user
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // Any authenticated user can create their own doc (signup flow).
      allow create: if request.auth != null && request.auth.uid == uid;

      // Users can update their own doc. The plan-field guard was removed
      // in Phase 5 alongside the plan field itself.
      allow update: if request.auth != null
        && request.auth.uid == uid;

      // Morning gists — readable by owning user; written by Cloud Functions (Admin SDK)
      match /morningGists/{gistId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // OAuth integration tokens — never accessible from client
      match /integrations/{doc} {
        allow read, write: if false;
      }
    }
  }
}
