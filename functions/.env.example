# Local-dev placeholders for the secrets Cloud Functions expect.
# Production values live in Firebase Secret Manager (firebase functions:secrets:set).
# Copy to functions/.env for local emulator runs. NEVER commit a real .env.

# 32-byte base64 key for field encryption (issue #177). Generate: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=
# 32-byte base64 key for signing email-feedback links. Generate: openssl rand -base64 32
FEEDBACK_LINK_SECRET=

ANTHROPIC_API_KEY=
RESEND_API_KEY=
WEATHERAPI_KEY=
NYT_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
