rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profile document — owned by the authenticated user
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // Any authenticated user can create their own doc (signup flow).
      allow create: if request.auth != null && request.auth.uid == uid;

      // Users can update their own doc. The plan-field guard was removed
      // in Phase 5 alongside the plan field itself.
      allow update: if request.auth != null
        && request.auth.uid == uid;

      // Morning gists — readable by owning user; written by Cloud Functions (Admin SDK)
      match /morningGists/{gistId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // OAuth integration tokens — never accessible from client
      match /integrations/{doc} {
        allow read, write: if false;
      }
    }
  }
}
